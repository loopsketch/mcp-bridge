MCP_TRANSPORT=streamable-http
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=8000
LLAMA_CPP_SERVER_URL=http://localhost:8080/v1/chat/completions
LLAMA_CPP_SERVER_MODEL=
LLAMA_CPP_SERVER_TIMEOUT=90

# 認証用トークン (32文字以上必須)。例: openssl rand -hex 32
MCP_API_TOKEN=REPLACE_WITH_MCP_API_TOKEN

# 入力(question + code_context)の合計文字数上限
MAX_INPUT_CHARS=200000
